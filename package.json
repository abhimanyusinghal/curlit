{
  "name": "curlit",
  "version": "1.4.0",
  "description": "A fast, modern, open-source API testing tool.",
  "license": "MIT",
  "author": {
    "name": "Abhimanyu Singhal",
    "email": "abhimanyu.singhal@live.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abhimanyusinghal/curlit.git"
  },
  "bugs": {
    "url": "https://github.com/abhimanyusinghal/curlit/issues"
  },
  "homepage": "https://github.com/abhimanyusinghal/curlit#readme",
  "engines": {
    "node": ">=22.12.0"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"node server/proxy.js\"",
    "dev:frontend": "vite",
    "dev:server": "node server/proxy.js",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:electron": "eslint electron",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:server": "vitest run server/__tests__/",
    "test:e2e": "npx playwright test",
    "bundle:agent": "node scripts/build-agent.mjs",
    "package:agent": "npm run bundle:agent && pkg dist-agent/agent.cjs --public --public-packages \"*\" --targets node22-win-x64,node22-macos-x64,node22-linux-x64 --out-path dist-agent",
    "electron:dev": "concurrently -k -n vite,electron -c cyan,magenta \"vite\" \"wait-on tcp:5173 && cross-env CURLIT_DEV_URL=http://localhost:5173 node scripts/run-electron.cjs electron/main.cjs\"",
    "build:desktop": "tsc -b && vite build --base=./",
    "electron:build": "npm run build:desktop && electron-builder --publish never",
    "electron:build:win": "npm run build:desktop && electron-builder --win --publish never",
    "electron:build:mac": "npm run build:desktop && electron-builder --mac --publish never",
    "electron:build:linux": "npm run build:desktop && electron-builder --linux --publish never",
    "electron:package": "npm run build:desktop && electron-builder --dir --publish never",
    "electron:package:win": "npm run build:desktop && electron-builder --win --dir --publish never",
    "electron:package:mac": "npm run build:desktop && electron-builder --mac --dir --publish never",
    "electron:package:linux": "npm run build:desktop && electron-builder --linux --dir --publish never"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@uiw/react-codemirror": "^4.25.9",
    "cm6-graphql": "^0.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "js-yaml": "^5.2.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-resizable-panels": "^4.9.0",
    "undici": "^7.28.0",
    "ws": "^8.21.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.7",
    "@yao-pkg/pkg": "^6.5.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.5"
  },
  "optionalDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.0.0-rc.13",
    "@rollup/rollup-win32-x64-msvc": "^4.60.1",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.2",
    "lightningcss-win32-x64-msvc": "^1.32.0"
  }
}
